{
  "name": "Zigbee2MQTT (Gebäude Post / SLZB-06p7)",
  "version": "2.12.1-1",
  "slug": "zigbee2mqtt_gebaeudepost",
  "description": "Zusätzliche Zigbee2MQTT-Instanz für einen netzwerkgebundenen SLZB-06p7-Koordinator (Gebäude Post – ehemaliges Restaurant „Zur Post\", benannt nach der früheren Post-Station)",
  "url": "https://github.com/scaiandre/hassio-artnet-addon-repository/tree/master/zigbee2mqtt-gebaeudepost",
  "startup": "application",
  "services": [
    "mqtt:need"
  ],
  "arch": [
    "aarch64",
    "amd64",
    "armhf",
    "armv7",
    "i386"
  ],
  "boot": "auto",
  "init": false,
  "ingress": true,
  "panel_icon": "mdi:zigbee",
  "map": [
    {
      "type": "share",
      "read_only": false
    },
    {
      "type": "homeassistant_config",
      "read_only": false,
      "path": "/config"
    },
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/addon_config"
    }
  ],
  "options": {
    "data_path": "/config/zigbee2mqtt_gebaeudepost",
    "mqtt": {
      "base_topic": "zigbee2mqtt_gebaeudepost"
    },
    "serial": {
      "port": "tcp://192.0.2.21:6638",
      "adapter": "zstack"
    }
  },
  "schema": {
    "data_path": "str",
    "mqtt": {
      "server": "str?",
      "ca": "str?",
      "key": "str?",
      "cert": "str?",
      "user": "str?",
      "password": "str?",
      "base_topic": "str?"
    },
    "serial": {
      "port": "str?",
      "adapter": "match(zstack|deconz|zigate|ezsp|ember|zboss)?",
      "baudrate": "int?",
      "rtscts": "bool?"
    },
    "watchdog": "str?",
    "force_onboarding": "bool?"
  },
  "image": "ghcr.io/zigbee2mqtt/zigbee2mqtt-{arch}"
}
